generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String          @id @default(uuid())
  name              String
  email             String          @unique
  password          String
  phone             String          @unique
  shopName          String
  role              String          @default("user") // "admin", "user" (owner), "employee"
  isActive          Boolean         @default(true)
  isArchived        Boolean         @default(false)
  subscriptionStart DateTime?
  subscriptionEnd   DateTime?
  createdAt         DateTime        @default(now())
  monthlyAmount     Float?
  
  // Relations for data ownership
  customers         Customer[]
  invoices          Invoice[]       @relation("ShopInvoices")
  products          Product[]
  supportTickets    SupportTicket[]

  // New: Relations for Employee/Owner hierarchy
  ownerId           String?
  owner             User?           @relation("ShopEmployees", fields: [ownerId], references: [id])
  employees         User[]          @relation("ShopEmployees")

  // New: Relation for tracking who created the invoice
  createdInvoices   Invoice[]       @relation("InvoiceCreator")
}

model Customer {
  id         String    @id @default(uuid())
  name       String
  phone      String
  isArchived Boolean   @default(false)
  userId     String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices Invoice[]
}

model Invoice {
  id          String        @id @default(uuid())
  totalAmount Float         @default(0)
  status      String        @default("pending")
  userId      String        // The Shop (Owner) this invoice belongs to
  customerId  String
  createdAt   DateTime      @default(now())
  customer    Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user        User          @relation("ShopInvoices", fields: [userId], references: [id], onDelete: Cascade)
  items       InvoiceItem[]

  // New: Track who specifically generated this
  createdById String?
  creator     User?         @relation("InvoiceCreator", fields: [createdById], references: [id], onDelete: SetNull)
}

model InvoiceItem {
  id        String  @id @default(uuid())
  name      String
  price     Float
  quantity  Int
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id         String   @id @default(uuid())
  subject    String
  message    String
  adminReply String?
  status     String   @default("open")
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id        String   @id @default(uuid())
  name      String
  sku       String?
  price     Float
  category  String?  @default("General")
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
