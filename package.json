{
  "name": "billflow",
  "version": "1.0.0",
  "main": "electron/main.js",
  "description": "BillFlow – WhatsApp Billing SaaS",
  "author": "BillFlow Team",
  "scripts": {
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "db:migrate": "cd backend && npm run db:migrate",
    "db:generate": "cd backend && npm run db:generate",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "build": "npm run build:backend && npm run build:frontend",
    "start": "cd backend && npm start",
    "start:desktop": "electron electron/main.js",
    "package:linux": "npm run build:frontend && electron-builder --linux",
    "package:win": "npm run build:frontend && electron-builder --win",
    "package:mac": "npm run build:frontend && electron-builder --mac",
    "package:all": "npm run build:frontend && electron-builder --linux --win --mac"
  },
  "build": {
    "productName": "BillFlow",
    "appId": "com.billflow.app",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "electron/icon.png"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "icon": "electron/icon.png",
      "category": "Office"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon": "electron/icon.png",
      "category": "public.app-category.business"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0",
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  }
}
